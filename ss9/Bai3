import random
a = int(input("Hãy chọn số bất kì từ 1 đến 10 trong 3 lần: "))
b = random.randint(1,10)
i = 1
while i < 3:
    if a == b:
        print("Bạn đã đoán đúng")
        break
    else: 
        print("Bạn đã đoán sai")
        i += 1
        a = int(input("Bạn hãy đoán lại: "))
else:
    print("Bạn đã thua")