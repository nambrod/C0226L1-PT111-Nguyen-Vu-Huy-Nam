import random
a = int(input("Hãy chọn số bất kì trong 7 lần: "))
b = random.randint(1,10)
i = 1
while i < 7:
    if a == b:
        print("Bạn đã đoán đúng")
        break
    else: 
        print("Bạn đã đoán sai")
        i += 1
        a = int(input("Bạn hãy đoán lại: "))
else:
    print("Bạn đã thua")